From 58978164bb993023abac02d997b81a2df658ab69 Mon Sep 17 00:00:00 2001
From: Serbur <19244210+MLG-SERBUR@users.noreply.github.com>
Date: Tue, 21 Apr 2026 00:55:49 +0000
Subject: [PATCH] ci: add --no-transfer-progress to batch-mode maven commands

---
 .github/workflows/ci.yml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
index a5fc03a..e07fc4d 100644
--- a/.github/workflows/ci.yml
+++ b/.github/workflows/ci.yml
@@ -25,7 +25,7 @@ jobs:
           distribution: 'temurin'
 
       - name: Build and Test
-        run: mvn --batch-mode clean verify
+        run: mvn --batch-mode --no-transfer-progress clean verify
 
       - name: Extract Final Artifact Name from POM
         if: github.event_name == 'release'
-- 
2.43.0

