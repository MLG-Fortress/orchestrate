From 3ba94d3330c54ff5f8de41c9d3dcc65ae6585844 Mon Sep 17 00:00:00 2001
From: Serbur <19244210+MLG-SERBUR@users.noreply.github.com>
Date: Tue, 21 Apr 2026 00:50:35 +0000
Subject: [PATCH] ci: add --no-transfer-progress to maven verify step

---
 .github/workflows/ci.yaml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/.github/workflows/ci.yaml b/.github/workflows/ci.yaml
index a5fc03a..e07fc4d 100644
--- a/.github/workflows/ci.yaml
+++ b/.github/workflows/ci.yaml
@@ -25,7 +25,7 @@ jobs:
           distribution: 'temurin'
 
       - name: Build and Test
-        run: mvn --batch-mode clean verify
+        run: mvn --batch-mode --no-transfer-progress clean verify
 
       - name: Extract Final Artifact Name from POM
         if: github.event_name == 'release'
-- 
2.43.0

